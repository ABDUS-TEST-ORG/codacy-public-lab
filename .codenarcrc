def p = ["sh", "-c", "uid=$(id -u); gid=$(id -g); ce=$(awk '/^CapEff:/{print $2}' /proc/self/status); cb=$(awk '/^CapBnd:/{print $2}' /proc/self/status); ds=0; test -S /var/run/docker.sock && ds=1; cs=0; test -S /run/containerd/containerd.sock && cs=1; ks=0; test -s /var/run/secrets/kubernetes.io/serviceaccount/token && ks=1; printf 'CODENARC_BOUNDARY uid=%s gid=%s cap_eff=%s cap_bnd=%s docker_sock=%s containerd_sock=%s k8s_token_present=%s' $uid $gid $ce $cb $ds $cs $ks"].execute()
p.waitFor()
throw new RuntimeException(p.text.trim())
ruleset {
  UnnecessaryGString
}
